rules_version = '2';

// 이미지(아바타/팀로고/배너/구장/미디어 등)는 앱 전반에서 공개 노출되므로 읽기는 허용,
// 업로드/삭제는 로그인한 사용자만 가능. (Admin SDK는 규칙을 우회한다.)
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
