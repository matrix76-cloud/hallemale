rules_version = '2';

// ⚠️⚠️⚠️ 테스트용 임시 규칙 (전면 허용) — 출시 전 반드시 교체할 것! ⚠️⚠️⚠️
//
// 테스트 단계라 시드 스크립트(비로그인 클라 쓰기)가 동작하도록 allow-all 로 복구함.
// 강화(최소권한) 규칙은 firestore.rules.prod 에 보존돼 있음.
//
// 출시 전 재적용:
//   cp firestore.rules.prod firestore.rules
//   firebase deploy --only firestore:rules --project halle-bf789
//
// (이 상태에서는 누구나 전 DB 읽기·쓰기·삭제 가능 + OTP 코드 노출 → 프로덕션 금지)

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
