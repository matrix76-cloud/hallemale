rules_version = '2';

// 할래말래 Firestore 보안 규칙
// 원칙:
//  1) 익명(비로그인) 쓰기 전면 차단 — 기존 allow-all 최대 구멍(누구나 전 DB 수정·삭제 가능) 제거
//  2) 서버(Cloud Functions/Admin SDK) 전용 컬렉션은 클라이언트 접근 완전 차단
//     (OTP 코드·비번 재설정 로그·시스템 락 노출 차단. Admin SDK는 규칙을 우회하므로 함수는 정상 동작)
//  3) admin_accounts 는 어드민 커스텀 클레임(admin==true) 필요
//  4) 읽기는 기존 동작 유지(비로그인/교차 조회에 의존하는 화면 다수) — 민감 컬렉션만 제한
//  5) 열거되지 않은 컬렉션은 기본 차단(default deny)
// 주의: Firestore 규칙은 여러 match 가 OR 로 합쳐진다 → 넓은 read:true 캐치올을 두면
//       좁은 deny 가 무력화되므로, 잠글 컬렉션을 위해 전 컬렉션을 명시 열거한다.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isAdmin()  { return signedIn() && request.auth.token.admin == true; }

    // ───── 유저 / 팀 / 매칭 (공개 읽기, 로그인 쓰기) ─────
    match /users/{id}                    { allow read: if true; allow write: if signedIn(); }
    match /users_by_phone/{id}           { allow read: if true; allow write: if signedIn(); }
    match /phones/{id}                    { allow read: if true; allow write: if signedIn(); }
    match /clubs/{id}                     { allow read: if true; allow write: if signedIn(); }
    match /clubs/{id}/{sub=**}            { allow read: if true; allow write: if signedIn(); }
    // 팀 초대: collectionGroup(invites) 조회 지원 (MyTeamInvitesPage)
    match /{path=**}/invites/{inviteId}  { allow read: if signedIn(); allow write: if signedIn(); }
    match /match_requests/{id}            { allow read: if true; allow write: if signedIn(); }
    // 팀원→팀장 매칭 제안 원장(dedup + 성사 통보 대상). 로그인 사용자만 접근.
    match /match_proposals/{id}           { allow read: if signedIn(); allow write: if signedIn(); }
    match /rankings/{id}                  { allow read: if true; allow write: if signedIn(); }
    match /player_sessions/{id}           { allow read: if true; allow write: if signedIn(); }

    // ───── 구장 / 예약 ─────
    // 예약 가능 창구: 오늘 ~ +20일 (src/constants/booking.js BOOKING_WINDOW_DAYS = 21, 오늘 포함 3주).
    // 여기선 기기 시계·타임존 오차 흡수를 위해 하루 여유를 둬 +21일까지 허용한다.
    // (기준 시각은 KST = request.time(UTC) + 9h)
    function kstYmd(plusDays) {
      let t = request.time + duration.value(9, 'h') + duration.value(plusDays, 'd');
      return string(t.year()) + '-'
        + (t.month() < 10 ? '0' : '') + string(t.month()) + '-'
        + (t.day() < 10 ? '0' : '') + string(t.day());
    }
    function inBookingWindow(d) {
      return d is string && d >= kstYmd(0) && d <= kstYmd(21);
    }
    // 구장주 수동·정기대관(최대 52주)은 창구 예외 — venues 문서의 ownerUid 로 실제 소유자만 인정
    function isVenueOwner(venueId) {
      return signedIn() && venueId is string && venueId != ''
        && exists(/databases/$(database)/documents/venues/$(venueId))
        && get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == request.auth.uid;
    }

    match /venues/{id}                    { allow read: if true; allow write: if signedIn(); }
    match /venueReviews/{id}              { allow read: if true; allow write: if signedIn(); }
    match /venueReservations/{id} {
      allow read: if true;
      allow create: if signedIn()
                    && (inBookingWindow(request.resource.data.date)
                        || isVenueOwner(request.resource.data.venueId)
                        || isAdmin());
      // 만들어둔 예약의 날짜만 미래로 옮겨 창구를 우회하는 것도 차단 (날짜 그대로면 기존대로 허용)
      allow update: if signedIn()
                    && (request.resource.data.date == resource.data.date
                        || inBookingWindow(request.resource.data.date)
                        || isVenueOwner(resource.data.venueId)
                        || isAdmin());
      allow delete: if signedIn();
    }
    match /venueBlocks/{id}               { allow read: if true; allow write: if signedIn(); }
    match /gyms/{id}                      { allow read: if true; allow write: if signedIn(); }

    // ───── 채팅 / 커뮤니티 ─────
    match /chatRooms/{id}                 { allow read: if true; allow write: if signedIn(); }
    match /chatRooms/{id}/{sub=**}        { allow read: if true; allow write: if signedIn(); }
    match /community_posts/{id}           { allow read: if true; allow write: if signedIn(); }
    match /community_posts/{id}/{sub=**}  { allow read: if true; allow write: if signedIn(); }

    // ───── 알림 / 기기 토큰 ─────
    match /notifications/{id}             { allow read: if true;      allow write: if signedIn(); }
    match /fcmTokens/{id}                 { allow read: if signedIn(); allow write: if signedIn(); }

    // ───── 공개 콘텐츠 (읽기 공개 / 쓰기 어드민) ─────
    match /banners/{id}                   { allow read: if true; allow write: if isAdmin(); }
    match /notices/{id}                    { allow read: if true; allow write: if isAdmin(); }
    match /event_popups/{id}              { allow read: if true; allow write: if isAdmin(); }
    match /app_updates/{id}               { allow read: if true; allow write: if isAdmin(); }
    match /legal_documents/{id}           { allow read: if true; allow write: if isAdmin(); }
    match /games/{id}                     { allow read: if true; allow write: if isAdmin(); }

    // ───── 문의 / 신고 / 차단 (비공개 읽기, 로그인 쓰기) ─────
    match /inquiries/{id}                 { allow read: if signedIn(); allow write: if signedIn(); }
    match /community_reports/{id}         { allow read: if signedIn(); allow write: if signedIn(); }
    match /team_reports/{id}              { allow read: if signedIn(); allow write: if signedIn(); }
    match /user_reports/{id}              { allow read: if signedIn(); allow write: if signedIn(); }
    match /user_blocks/{id}               { allow read: if signedIn(); allow write: if signedIn(); }

    // ───── 운영 작업 큐 ─────
    match /tasks/{id}                     { allow read: if true; allow write: if signedIn(); }

    // ───── 어드민 계정 (어드민 전용) ─────
    match /admin_accounts/{id}            { allow read: if isAdmin(); allow write: if isAdmin(); }

    // ───── 서버(Cloud Functions / Admin SDK) 전용 : 클라 접근 전면 차단 ─────
    match /phone_verifications/{id}       { allow read, write: if false; }
    match /password_reset_logs/{id}       { allow read, write: if false; }
    match /_system/{id}                   { allow read, write: if false; }

    // ───── 그 외 미열거 컬렉션 : 기본 차단 ─────
    match /{document=**}                  { allow read, write: if false; }
  }
}
